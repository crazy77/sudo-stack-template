{
  "name": "@sudo/db",
  "version": "1.0.0",
  "exports": {
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "dependencies": {
    "@sudo/env": "workspace:*",
    "@supabase/supabase-js": "^2.43.1",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "bun --env-file=../../.env.local ./node_modules/.bin/drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env.local ./node_modules/.bin/drizzle-kit generate && bun --env-file=../../.env.local ./node_modules/.bin/drizzle-kit migrate",
    "db:studio": "bun --env-file=../../.env.local ./node_modules/.bin/drizzle-kit studio"
  }
}
